# Environment Variables Template for DBUFF Application
# Copy this file to .env and set your actual API keys

# Scrapper API Key (ScraperAPI)
# Get your key from: https://www.scraperapi.com/
SCRAPPER_API_KEY=your_scrapper_api_key_here

# Dota API Key (OpenDota API)
# Get your key from: https://www.opendota.com/api-keys
DOTA_API_KEY=your_dota_api_key_here

# OpenAI API Key (for AI-based match analysis)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here


DISCORD_BOT_TOKEN